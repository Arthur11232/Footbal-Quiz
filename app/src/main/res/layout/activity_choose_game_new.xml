            android:layout_weight="1">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/black_poligon" />
        </FrameLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/L3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="-75dp"
        android:layout_marginTop="-41dp"
        android:layout_marginEnd="-75dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/L1">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/black_poligon" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnVersus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/select_game_grey">

            <!--<ImageView-->
            <!--android:layout_width="match_parent"-->
            <!--android:layout_height="match_parent"-->
            <!--android:background="@drawable/gray_poligon" />-->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="@string/versus_category"
                android:textColor="#000"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btn_coming"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/gray_poligon">

            <!--<ImageView-->
            <!--android:layout_width="match_parent"-->
            <!--android:layout_height="match_parent"-->
            <!--android:alpha="0.4"-->
            <!--android:background="@drawable/select_game_grey" />-->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:gravity="top|center"
                android:text="@string/coming_soon"
                android:textColor="#fff"
                android:visibility="gone"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cs_future_versus"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:visibility="gone"
                android:text="@string/coming_soon_game"
                android:textColor="#fff"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:ignore="SmallSp" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/black_poligon" />
        </FrameLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/L6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="-75dp"
        android:layout_marginTop="-41dp"
        android:layout_marginEnd="-75dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/L5">

