<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@drawable/football"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_gravity="center"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/fq_colorWhite" />

    </com.google.android.material.appbar.AppBarLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/app_bar"
        android:background="#74000000" />

    <Button
        android:id="@+id/tvGame"
        android:layout_width="170dp"
        android:layout_height="40dp"
        android:layout_centerHorizontal="true"
        android:layout_centerInParent="true"
        android:layout_centerVertical="true"
        android:layout_marginTop="150dp"
        android:background="@drawable/button_start_game"
        android:text="@string/new_game"
        android:textColor="#fff"
        android:textStyle="bold" />

    <Button
        android:id="@+id/tvContinue"
        android:layout_width="170dp"
        android:layout_height="40dp"
        android:layout_below="@+id/tvGame"
        android:layout_centerHorizontal="true"
        android:layout_centerInParent="true"
        android:layout_centerVertical="true"
        android:layout_margin="15dp"
        android:background="@drawable/button_start_game"
        android:text="@string/Continue"
        android:textColor="#fff"
        android:textStyle="bold" />

    <Button
        android:id="@+id/tvLanguage"
        android:layout_width="170dp"
        android:layout_height="40dp"
        android:layout_below="@+id/tvContinue"
        android:layout_centerHorizontal="true"
        android:layout_centerInParent="true"
        android:layout_centerVertical="true"
        android:background="@drawable/button_start_game"
        android:text="@string/Language"
        android:textColor="#fff"
        android:textStyle="bold" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/sign_in_play"
        android:visibility="visible"
        android:drawableStart="@drawable/ic_google_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@+id/agreement"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="54dp"
        android:text="@string/login_with_google"
        style="@style/FQ_Buttons"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/my_account"
        android:text="@string/user"
        android:visibility="gone"
        android:layout_above="@+id/agreement"
        android:layout_width="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_height="wrap_content"
        android:textColor="@color/fq_colorWhite"
        android:textSize="14sp"
        android:layout_marginBottom="54dp"/>


    <androidx.appcompat.widget.AppCompatTextView
        android:layout_alignParentBottom="true"
        android:id="@+id/agreement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:paddingEnd="24dp"
        android:paddingStart="24dp"
        android:layout_marginBottom="32dp"
        android:text="@string/agree_to"
        android:textColor="@color/fq_colorWhite"
        android:textSize="12sp" />


</RelativeLayout>