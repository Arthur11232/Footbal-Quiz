<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/football">

    <!-- Затемнение фона -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Кнопка назад -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/onBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/profile_guest"
                android:padding="8dp"
                android:src="@drawable/baseline_keyboard_backspace_24"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/fq_colorWhite" />

            <!-- Заголовок -->
            <TextView
                android:id="@+id/profileTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_title"
                android:textColor="@color/fq_colorWhite"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/onBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/onBack"
                tools:text="Profile" />

            <!-- Контейнер для фото -->
            <FrameLayout
                android:id="@+id/photoContainer"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginTop="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/onBack">

                <com.arthuralexandryan.footballquiz.views.CircleImageView
                    android:id="@+id/userPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ronaldo"
                    app:civ_border_color="@color/fq_colorWhite"
                    app:civ_border_width="2dp" />

                <ProgressBar
                    android:id="@+id/uploadProgress"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btnEditPhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:contentDescription="@string/profile_guest"
                    android:src="@drawable/ic_camera"
                    app:backgroundTint="@color/fq_colorBackground"
                    app:fabSize="mini"
                    app:tint="@color/fq_colorWhite" />
            </FrameLayout>

            <!-- Имя и Email -->
            <TextView
                android:id="@+id/userName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/profile_guest"
                android:textColor="@color/fq_colorWhite"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/photoContainer" />

            <TextView
                android:id="@+id/userEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/profile_not_signed_in"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/userName" />

            <!-- Разделитель -->
            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:background="#33FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/userEmail" />

            <TextView
                android:id="@+id/tvStatsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/profile_statistics"
                android:textColor="@color/fq_colorWhite"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider" />

            <!-- Sync Button -->
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnSync"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/profile_sync"
                android:padding="8dp"
                android:src="@drawable/ic_sync"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@id/tvStatsLabel"
                app:layout_constraintStart_toEndOf="@id/tvStatsLabel"
                app:layout_constraintTop_toTopOf="@id/tvStatsLabel"
                app:tint="@color/fq_colorWhite" />

            <!-- Карточка: Total Score -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardTotalScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_stats_card"
                android:padding="16dp"
                app:layout_constraintEnd_toStartOf="@+id/cardAnswered"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvStatsLabel">

                <TextView
                    android:id="@+id/tvTotalScoreValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/fq_colorWhite"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/profile_total_score"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTotalScoreValue" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Карточка: Questions Answered -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardAnswered"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_stats_card"
                android:padding="16dp"
                app:layout_constraintBottom_toBottomOf="@id/cardTotalScore"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                app:layout_constraintStart_toEndOf="@+id/cardTotalScore"
                app:layout_constraintTop_toTopOf="@id/cardTotalScore">

                <TextView
                    android:id="@+id/tvAnsweredCountValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/fq_colorWhite"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/profile_questions_answered"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvAnsweredCountValue" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Кнопки Sign In / Sign Out -->
            <com.google.android.gms.common.SignInButton
                android:id="@+id/btnSignIn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardTotalScore" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSignOut"
                style="@style/FQ_Buttons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:text="@string/profile_sign_out"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardTotalScore" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
