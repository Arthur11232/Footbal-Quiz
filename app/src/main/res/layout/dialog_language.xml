<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EC055002"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/Language"
        android:textColor="@color/fq_colorWhite"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3Dffffff"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/app_languages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <RadioButton
            android:id="@+id/lng_english"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textColor="@color/fq_colorWhite"
            android:buttonTint="@color/fq_colorWaitingAnswer"
            android:paddingStart="12dp"
            android:textStyle="bold"
            android:textSize="16sp"
            android:text="🇬🇧  English" />

        <RadioButton
            android:id="@+id/lng_armenian"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textColor="@color/fq_colorWhite"
            android:buttonTint="@color/fq_colorWaitingAnswer"
            android:paddingStart="12dp"
            android:textStyle="bold"
            android:textSize="16sp"
            android:text="🇦🇲  Հայերեն" />

        <RadioButton
            android:id="@+id/lng_russian"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textColor="@color/fq_colorWhite"
            android:buttonTint="@color/fq_colorWaitingAnswer"
            android:paddingStart="12dp"
            android:textStyle="bold"
            android:textSize="16sp"
            android:text="🇷🇺  Русский" />
    </RadioGroup>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3Dffffff"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/save_language"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="OK"
        android:textColor="@color/fq_colorWhite"
        android:textStyle="bold"
        android:background="@drawable/button_start_game" />

</LinearLayout>
