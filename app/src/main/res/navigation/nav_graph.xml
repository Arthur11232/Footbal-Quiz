<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.SplashFragment"
        android:label="SplashFragment"
        tools:layout="@layout/splash">
        <action
            android:id="@+id/action_splash_to_start"
            app:destination="@id/startPageFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/startPageFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.StartPageFragment"
        android:label="StartPageFragment"
        tools:layout="@layout/activity_start_page">
        <action
            android:id="@+id/action_start_to_choose"
            app:destination="@id/chooseGameFragment" />
        <action
            android:id="@+id/action_start_to_privacy"
            app:destination="@id/privacyPolicyFragment" />
        <action
            android:id="@+id/action_start_to_terms"
            app:destination="@id/termsFragment" />
        <action
            android:id="@+id/action_start_to_profile"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/chooseGameFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.ChooseGameFragment"
        android:label="ChooseGameFragment"
        tools:layout="@layout/activity_choose_game">
        <action
            android:id="@+id/action_choose_to_category"
            app:destination="@id/categoryPageFragment" />
        <action
            android:id="@+id/action_choose_to_versus"
            app:destination="@id/versusFragment" />
    </fragment>

    <fragment
        android:id="@+id/categoryPageFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.CategoryPageFragment"
        android:label="CategoryPageFragment"
        tools:layout="@layout/activity_category_page">
        <argument
            android:name="gameScore"
            app:argType="string" />
        <action
            android:id="@+id/action_category_to_play"
            app:destination="@id/playFragment" />
    </fragment>

    <fragment
        android:id="@+id/versusFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.VersusFragment"
        android:label="VersusFragment"
        tools:layout="@layout/activity_versus">
        <action
            android:id="@+id/action_versus_to_play"
            app:destination="@id/playFragment" />
    </fragment>

    <fragment
        android:id="@+id/playFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.PlayFragment"
        android:label="PlayFragment"
        tools:layout="@layout/activity_play_new">
        <argument
            android:name="harcer"
            app:argType="com.arthuralexandryan.footballquiz.models.GameObjectSerializable[]" />
        <argument
            android:name="achokner"
            app:argType="com.arthuralexandryan.footballquiz.models.GameObjectScores" />
        <argument
            android:name="cat_score"
            app:argType="com.arthuralexandryan.footballquiz.models.GameObjectScores" />
        <argument
            android:name="title"
            app:argType="string" />
        <argument
            android:name="category"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/privacyPolicyFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.PrivacyPolicyFragment"
        android:label="PrivacyPolicyFragment"
        tools:layout="@layout/activity_privacy_policy" />

    <fragment
        android:id="@+id/termsFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.TermsFragment"
        android:label="TermsFragment"
        tools:layout="@layout/activity_terms" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.ProfileFragment"
        android:label="ProfileFragment"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/testFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.TestFragment"
        android:label="TestFragment"
        tools:layout="@layout/activity_test">
        <action
            android:id="@+id/action_test_to_touch"
            app:destination="@id/touchFragment" />
    </fragment>

    <fragment
        android:id="@+id/touchFragment"
        android:name="com.arthuralexandryan.footballquiz.fragments.TouchFragment"
        android:label="TouchFragment"
        tools:layout="@layout/activity_touch" />

</navigation>
